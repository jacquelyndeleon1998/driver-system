<script>
const sheetURL = "PASTE_YOUR_CSV_LINK_HERE";

async function loadTrips() {
  const response = await fetch(sheetURL);
  const data = await response.text();

  const rows = data.trim().split("\n").slice(1);
  const table = document.getElementById("tripTable");

  rows.forEach(row => {
    const cols = row.split(",");

    if (cols.length < 7) return;

    const html = `
      <tr>
        <td>${cols[1]}</td>  <!-- Date -->
        <td>${cols[0]}</td>  <!-- Driver -->
        <td>${cols[3]}</td>  <!-- Vehicle -->
        <td>${cols[4]}</td>  <!-- Requested By -->
        <td>${cols[5]}</td>  <!-- Origin -->
        <td>${cols[6]}</td>  <!-- Destination -->
        <td>
          <button onclick="submitAllowance('${cols[0]}','${cols[1]}')">
            Submit
          </button>
        </td>
      </tr>
    `;

    table.innerHTML += html;
  });
}

function submitAllowance(driver, date) {
  alert("Allowance request for " + driver + " on " + date);
}

loadTrips();
</script>
